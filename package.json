{
  "name": "@zitadel/nuxt-auth",
  "description": "A comprehensive Auth.js integration for Nuxt 4 applications with TypeScript support and OAuth providers",
  "version": "1.1.1",
  "type": "module",
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zitadel/nuxt-auth.git"
  },
  "author": {
    "name": "Mridang Agarwalla",
    "email": "mridang@zitadel.com",
    "url": "https://github.com/zitadel"
  },
  "workspaces": [
    "playground-authjs"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "build": "nuxi build",
    "clean": "rm -rf playground-authjs/.nuxt dist .nuxt",
    "depcheck": "npx knip",
    "dev:prepare": "nuxt-module-build build --stub",
    "docs:build": "typedoc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --max-warnings=0 --fix",
    "test:unit": "vitest",
    "typecheck": "nuxi prepare playground-authjs && tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "defu": "^6.1.4",
    "h3": "^1.15.5",
    "requrl": "^3.0.2",
    "ufo": "^1.6.3"
  },
  "peerDependencies": {
    "@auth/core": ">=0.40.0",
    "@nuxt/schema": "^4.0.0",
    "cookie-es": "^1.0.0",
    "radix3": "^1.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@mridang/eslint-defaults": "^1.0.0",
    "@nuxt/eslint-plugin": "^1.0.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/test-utils": "^3.23.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.1.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.2",
    "knip": "^5.66.4",
    "nitropack": "^2.11.13",
    "nuxt": "^4.0.0",
    "prettier": "^3.5.3",
    "semantic-release": "^25.0.1",
    "ts-essentials": "^10.1.1",
    "typedoc": "^0.28.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "auth",
    "authentication",
    "@auth",
    "@auth/core",
    "authjs",
    "jwt",
    "oauth",
    "nuxt-auth",
    "vue"
  ],
  "private": false,
  "homepage": "https://github.com/zitadel/nuxt-auth",
  "bugs": "https://github.com/zitadel/nuxt-auth/issues",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
