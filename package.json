{
  "name": "@sidebase/nuxt-auth",
  "version": "1.1.1",
  "license": "MIT",
  "type": "module",
  "description": "Authentication built for Nuxt 4! Easily add authentication via OAuth providers, credentials or Email Magic URLs!",
  "homepage": "https://auth.sidebase.io",
  "repository": "github:sidebase/nuxt-auth",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "playground-authjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "build": "nuxi build",
    "lint": "oxlint --deny-warnings -D correctness -D suspicious -D perf -D no-unused-vars && eslint . --max-warnings=0",
    "lint:fix": "eslint . --max-warnings=0 --fix",
    "clean": "rm -rf playground-authjs/.nuxt dist .nuxt",
    "typecheck": "nuxi prepare playground-authjs && tsc --noEmit",
    "dev:prepare": "nuxt-module-build build --stub",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test:unit": "vitest"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "defu": "^6.1.4",
    "h3": "^1.15.5",
    "requrl": "^3.0.2",
    "ufo": "^1.6.3"
  },
  "peerDependencies": {
    "next-auth": "~4.21.1"
  },
  "peerDependenciesMeta": {
    "next-auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.0.0",
    "@nuxt/eslint": "^1.7.1",
    "@types/node": "^22.15.29",
    "eslint": "^9.39.2",
    "nuxt": "^4.0.0",
    "ofetch": "^1.5.1",
    "oxlint": "^1.39.0",
    "ts-essentials": "^10.1.1",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.0.21",
	"vite": "^7.0.0",
	"nitropack": "^2.11.13"
  }
}
